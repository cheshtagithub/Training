<%= form_with model: task do |f| %>
    <div>
        <%= f.label :title %><br>
        <%= f.text_field :title %>
    </div>

    <div>
        <%= f.label :description %><br>
        <%= f.text_area :description %>
    </div>

    <div>
        <%= f.label  :status %><br>
        <%= f.select :status, ["pending","in_progres","completed"] %>
    </div>

    <div>
        <%= f.submit %>
    </div>

<% end %>