<h2>Login</h2>

<%= form_with url: "/login" do |f| %>
    <div>
        <label>Email</label><br>
        <%= f.email_field :email %>
    </div>

    <div>
        <label>Password</label><br>
        <%= f.password_field :password %>
    </div>

    <div>
        <%= f.submit "Login" %>
    </div>
<% end %>

<p>
  Don't have an account?
  <%= link_to "Sign Up", "/signup" %>
</p>