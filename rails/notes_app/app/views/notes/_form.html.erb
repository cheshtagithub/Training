<%= form_with(model: note) do |form| %>

    <% if note.errors.any? %>
        <div style="color: red">
            <% note.errors.full_messages.each do |msg| %>
                <p><%= msg %></p>
            <% end %>
        </div>
    <% end %>    

    <div>
        <%= form.label :title %>
        <%= form.text_field :title %>
    </div>

    <div>
        <%= form.label :content %>
        <%= form.text_area :content %>
    </div>

    <div>
        <%= form.submit %>
    </div>

<% end %>