<div class="page-container">

  <!-- HEADER -->
  <div class="page-header">
    <h1>Books</h1>
    <%= link_to "Add Book", new_book_path, class: "btn-primary" %>
  </div>

  <!-- 🔍 SEARCH FORM -->
  <div class="search-box">
    <%= form_with url: books_path,
                  method: :get,
                  data: { turbo_frame: "books_list" } do %>

      <%= text_field_tag :query,
            params[:query],
            placeholder: "Search books...",
            oninput: "this.form.requestSubmit()" %>

    <% end %>
  </div>

  <!-- 📚 BOOK LIST (Turbo Frame) -->
  <turbo-frame id="books_list">

    <div class="book-table">
      <table>
        <thead>
          <tr>
            <th>Title</th>
            <th>Author</th>
            <th>Genre</th>
            <th>Price</th>
            <th>Actions</th>
          </tr>
        </thead>

        <tbody>
          <% @books.each do |book| %>
            <tr>
              <td><%= book.title %></td>
              <td><%= book.author %></td>
              <td><%= book.genre %></td>
              <td>₹<%= book.price %></td>
              <td class="action-buttons">
                <%= link_to "Show", book_path(book), class: "btn-info" %>
                <%= link_to "Edit", edit_book_path(book), class: "btn-warning" %>
                <%= link_to "Delete", book_path(book),
                      data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                      class: "btn-danger" %>
              </td>
            </tr>
          <% end %>
        </tbody>

      </table>
    </div>

  </turbo-frame>

</div> <!-- ✅ THIS closes page-container -->